  <diagram name="Deployment Topology" id="deploy-topo">
    <mxGraphModel dx="1422" dy="868" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ====== Title ====== -->
        <mxCell id="title" value="DPP Capgemini — Deployment Topology" style="text;html=1;fontSize=22;fontStyle=1;align=center;fontColor=#354A5F;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="740" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Multi-Target Application: three deployment modules and three resources — Icons: SAP BTP Solution Diagrams (Apache-2.0)" style="text;html=1;fontSize=11;fontStyle=2;align=center;fontColor=#888;" vertex="1" parent="1">
          <mxGeometry x="380" y="52" width="740" height="20" as="geometry" />
        </mxCell>

        <!-- ====== Build Pipeline (top row) ====== -->
        <mxCell id="build-row" value="Build Pipeline (run locally)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999;dashed=1;verticalAlign=top;align=left;fontStyle=1;fontColor=#666;spacingLeft=10;spacingTop=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1380" height="130" as="geometry" />
        </mxCell>

        <mxCell id="src" value="Source Tree&#10;Approuter, Database model,&#10;Service code, MTA descriptor,&#10;Security profile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#888;fontColor=#333;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="140" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="npmci" value="Install dependencies&#10;and build the project&#10;(produces deployable artifacts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a6ed1;strokeColor=#0854A0;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="370" y="140" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mbt" value="Multi-Target Application&#10;Build&#10;Produces a deployable archive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00C19E;strokeColor=#008F77;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="600" y="140" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cfdeploy" value="Cloud Foundry Deploy&#10;Pushes the archive&#10;into the target space" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;strokeColor=#4A148C;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="910" y="140" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cups" value="Create Runtime Secrets&#10;(one-time per space)&#10;QR signing key and base URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;fontColor=#880E4F;fontSize=10;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="140" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="bp-e1" style="endArrow=classic;html=1;strokeColor=#888;" edge="1" parent="1" source="src" target="npmci">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="bp-e2" style="endArrow=classic;html=1;strokeColor=#888;" edge="1" parent="1" source="npmci" target="mbt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="bp-e3" style="endArrow=classic;html=1;strokeColor=#888;" edge="1" parent="1" source="mbt" target="cfdeploy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== Target: Subaccount/CF Space ====== -->
        <mxCell id="target" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF6FB;strokeColor=#0a6ed1;strokeWidth=3;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="1380" height="600" as="geometry" />
        </mxCell>
        <mxCell id="target-lbl" value="Deployment Target: BTP Subaccount in region eu10-004 · Cloud Foundry Org and Dev Space" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#0a6ed1;align=left;verticalAlign=middle;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="268" width="900" height="28" as="geometry" />
        </mxCell>

        <!-- === Modules Row === -->
        <mxCell id="mod-row" value="Modules — Cloud Foundry deploys these as three apps" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0a6ed1;dashed=1;verticalAlign=top;align=left;fontStyle=2;fontColor=#0a6ed1;spacingLeft=10;spacingTop=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="90" y="310" width="900" height="260" as="geometry" />
        </mxCell>

        <!-- Module 1: Approuter -->
        <mxCell id="m-app" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#008F77;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="110" y="350" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="m-app-title" value="Approuter Module" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#008F77;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="115" y="354" width="270" height="34" as="geometry" />
        </mxCell>
        <mxCell id="m-app-content" value="Application router runtime&#10;Small memory and disk footprint&#10;&#10;Responsibilities:&#10;• Serve static UI (Sprint 2+)&#10;• Terminate authentication&#10;• Forward requests to the backend&#10;• Pass the authentication header&#10;&#10;Exposes the public route." style="text;html=1;fontSize=10;fontColor=#333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="115" y="390" width="270" height="155" as="geometry" />
        </mxCell>

        <!-- Module 2: Backend Service (central) -->
        <mxCell id="m-srv" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0a6ed1;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="410" y="350" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="m-srv-title" value="Backend Service Module ★" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#0a6ed1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="415" y="354" width="270" height="34" as="geometry" />
        </mxCell>
        <mxCell id="m-srv-content" value="Node.js with SAP CAP framework&#10;Single instance, modest memory&#10;&#10;Responsibilities:&#10;• Authenticated OData V4 service&#10;• Public REST endpoints&#10;• Swagger documentation&#10;• Health check&#10;&#10;Exposes the service to the&#10;application router." style="text;html=1;fontSize=10;fontColor=#333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="415" y="390" width="270" height="155" as="geometry" />
        </mxCell>

        <!-- Module 3: Database Deployer -->
        <mxCell id="m-dep" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF8200;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="710" y="350" width="260" height="200" as="geometry" />
        </mxCell>
        <mxCell id="m-dep-title" value="Database Deployer Module (one-shot)" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#FF8200;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="715" y="354" width="250" height="34" as="geometry" />
        </mxCell>
        <mxCell id="m-dep-content" value="HDI deployer runtime&#10;Small memory and disk footprint&#10;&#10;Responsibilities:&#10;• Translate the data model&#10;  into HANA tables and views&#10;• Run once after each deploy&#10;• Exit cleanly when finished&#10;&#10;Connects to the database&#10;container." style="text;html=1;fontSize=10;fontColor=#333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="715" y="390" width="250" height="155" as="geometry" />
        </mxCell>

        <!-- === Resources Row === -->
        <mxCell id="res-row" value="Resources — Cloud Foundry services that the modules consume" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6A1B9A;dashed=1;verticalAlign=top;align=left;fontStyle=2;fontColor=#6A1B9A;spacingLeft=10;spacingTop=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="90" y="600" width="1330" height="240" as="geometry" />
        </mxCell>

        <!-- Resource: Database -->
        <mxCell id="r-db-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF8200;strokeWidth=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="110" y="640" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="r-db-title" value="Database Container" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#FF8200;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="115" y="642" width="270" height="34" as="geometry" />
        </mxCell>
        <mxCell id="r-db-icon" value="" style="shape=image;html=1;verticalAlign=middle;aspect=fixed;image=https://raw.githubusercontent.com/SAP/btp-solution-diagrams/main/assets/shape-libraries-and-editable-presets/svg/20083-sap-hana-cloud_sd.svg;" vertex="1" parent="1">
          <mxGeometry x="140" y="685" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r-db-content" value="HANA Cloud database&#10;in an isolated container&#10;&#10;• 11 catalogue tables&#10;• Shared HANA instance&#10;• Bound to the backend and&#10;  to the database deployer" style="text;html=1;fontSize=10;fontColor=#333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="210" y="685" width="175" height="120" as="geometry" />
        </mxCell>

        <!-- Resource: Authorization -->
        <mxCell id="r-uaa-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0a6ed1;strokeWidth=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="410" y="640" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="r-uaa-title" value="Authorization Service" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#0a6ed1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="415" y="642" width="310" height="34" as="geometry" />
        </mxCell>
        <mxCell id="r-uaa-icon" value="" style="shape=image;html=1;verticalAlign=middle;aspect=fixed;image=https://raw.githubusercontent.com/SAP/btp-solution-diagrams/main/assets/shape-libraries-and-editable-presets/svg/31015-sap-authorization-and-trust-management-service_sd.svg;" vertex="1" parent="1">
          <mxGeometry x="430" y="685" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r-uaa-content" value="Authorization and Trust&#10;Management (XSUAA)&#10;Configured by the security profile&#10;&#10;• Dedicated tenant mode&#10;• Single Authenticated User scope&#10;• One role template&#10;• Default role collection&#10;• Three OAuth2 redirect URIs" style="text;html=1;fontSize=10;fontColor=#333;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="500" y="685" width="225" height="125" as="geometry" />
        </mxCell>

        <!-- Resource: Runtime Secrets -->
        <mxCell id="r-ups-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6A1B9A;strokeWidth=1;dashed=0;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="750" y="640" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="r-ups-title" value="Runtime Secrets (user-provided service)" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#6A1B9A;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="755" y="642" width="310" height="34" as="geometry" />
        </mxCell>
        <mxCell id="r-ups-icon" value="🔐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontColor=#4A148C;fontSize=28;align=center;" vertex="1" parent="1">
          <mxGeometry x="770" y="685" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r-ups-content" value="User-provided service holding&#10;runtime secrets&#10;&#10;Set up once per space&#10;by an operator.&#10;&#10;Contents:&#10;• QR token signing key&#10;• Public base URL&#10;&#10;Secrets can be rotated without&#10;a redeploy of the backend." style="text;html=1;fontSize=9;fontColor=#4A148C;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="840" y="685" width="225" height="125" as="geometry" />
        </mxCell>

        <!-- ====== External: Public Route (right side) ====== -->
        <mxCell id="ext-route-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=1;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1090" y="310" width="320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="ext-route-title" value="Public Route" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#1976D2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1100" y="315" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ext-route-content" value="The application router is the&#10;single public entry point.&#10;&#10;Reachable externally:&#10;• Single-sign-on landing&#10;• Authenticated OData V4 service&#10;• Public passport view by token&#10;• Swagger documentation&#10;• Health check&#10;&#10;The route URL is also written&#10;into every QR code." style="text;html=1;fontSize=10;fontColor=#0D47A1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1100" y="335" width="290" height="220" as="geometry" />
        </mxCell>

        <!-- ====== Binding edges ====== -->
        <mxCell id="bind-app-srv" value="Forwards request&#10;to the backend service&#10;with authentication header" style="endArrow=classic;html=1;rounded=0;strokeColor=#0a6ed1;strokeWidth=2;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="m-app" target="m-srv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="bind-srv-uaa" value="Requires authorization&#10;service" style="endArrow=classic;html=1;rounded=0;strokeColor=#0a6ed1;strokeWidth=1;dashed=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="m-srv" target="r-uaa-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="bind-srv-db" value="Requires database&#10;container" style="endArrow=classic;html=1;rounded=0;strokeColor=#FF8200;strokeWidth=2;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="m-srv" target="r-db-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="bind-srv-ups" value="Requires runtime secrets&#10;(injected at boot)" style="endArrow=classic;html=1;rounded=0;strokeColor=#6A1B9A;strokeWidth=1;dashed=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="m-srv" target="r-ups-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="bind-dep-db" value="Initial schema deploy" style="endArrow=classic;html=1;rounded=0;strokeColor=#FF8200;strokeWidth=2;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="m-dep" target="r-db-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="bind-app-uaa" value="Requires authorization service" style="endArrow=classic;html=1;rounded=0;strokeColor=#0a6ed1;strokeWidth=1;dashed=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="m-app" target="r-uaa-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="bind-app-route" value="Exposed via" style="endArrow=classic;html=1;rounded=0;strokeColor=#1976D2;strokeWidth=2;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="m-app" target="ext-route-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="bp-cups-ups" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#C2185B;strokeWidth=1;dashed=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cups" target="r-ups-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="bp-cfdeploy-target" value="Creates three modules&#10;and binds the managed services" style="endArrow=classic;html=1;rounded=0;strokeColor=#7B1FA2;strokeWidth=2;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cfdeploy" target="m-srv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== Legend ====== -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="60" y="880" width="1380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="legend-content" value="★ Primary application (carries the business logic)  |  Solid arrows: data flow or required dependency  |  Dashed arrows: optional bindings and one-time setup steps  |  Colours group services by type" style="text;html=1;fontSize=10;fontColor=#666;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="880" width="1380" height="50" as="geometry" />
        </mxCell>

      </root>
