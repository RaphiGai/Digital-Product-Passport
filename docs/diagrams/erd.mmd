%%{init: {'theme':'neutral', 'themeVariables': { 'fontSize': '14px'}}}%%
%% Semantic data model — entities and their relationships ONLY (deliberately
%% attribute-free). Field-level detail lives in technical-data-model.mmd.
%% State: main, July 2026 (17 entities; the Demo branch adds 3 catalogue entities).
erDiagram

    %% ---------- Organisation layer ----------
    Organisation     ||--o{ User               : "owns"
    Organisation     ||--o{ Business_Partner   : "owns"
    Organisation     ||--o{ Product            : "owns"
    Business_Partner ||--o{ Business_Partner_Role : "has roles"
    Business_Partner |o--o{ User               : "portal login for"

    %% ---------- Product layer ----------
    Product_Category |o--o{ Product            : "categorises"
    Product          ||--o{ Product_Variant    : "has variants"
    Product_Variant  ||--o{ Batch              : "produced in"
    Batch            ||--o{ Product_Item       : "serialised into"
    Business_Partner |o--o{ Batch              : "manufactures"
    Business_Partner |o--o{ Batch              : "supplies"

    %% Bill of materials (variant-level recipe)
    Product_Variant  ||--o{ Product_BOM        : "consumes"
    Product_BOM      }o--o| Product            : "uses as component"

    %% Per-batch component sourcing
    Batch            ||--o{ Batch_Component    : "sources per batch"
    Product_BOM      ||--o{ Batch_Component    : "instantiates BOM line"
    Batch_Component  }o--o| Business_Partner   : "supplied by"
    Batch_Component  }o--o| Batch              : "component batch"
    Batch_Component  }o--o| Product_Passport   : "component sub-DPP"

    %% Documents (certificates and proofs — product- OR batch-level, XOR)
    Product          |o--o{ Document           : "evidence for"
    Batch            |o--o{ Document           : "evidence for"
    Business_Partner |o--o{ Document           : "assigned to"

    %% ---------- Passport layer ----------
    Product          ||--o{ Product_Passport   : "described by"
    Product_Variant  |o--o{ Product_Passport   : "variant shown on"
    Batch            |o--o{ Product_Passport   : "narrowed to"
    Product_Item     |o--|| Product_Passport   : "carries unique DPP"
    Product_Passport ||--o{ QR_Code            : "QR history"
    Product_BOM      }o--o| Product_Passport   : "sub-DPP"
    Product_Passport ||--o{ DPP_Version        : "immutable versions"
    User             |o--o{ DPP_Version        : "changed by"
    Product_Passport |o--o{ DPP_Marketing_Link : "shows ad/info"
    Organisation     ||--o{ DPP_Marketing_Link : "owns (tenant scope)"

    %% ---------- Import staging ----------
    Organisation     |o--o{ Pending_Import     : "staged imports"
    User             |o--o{ Pending_Import     : "created / reviewed by"
