        <mxCell id="t-prod" value="&lt;b style=&quot;font-size:13px;color:#E65100&quot;&gt;Products&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;product_type — NVARCHAR(12) — Required, enum, Default finished&lt;br&gt;name — NVARCHAR(120) — Required&lt;br&gt;brand — NVARCHAR(120)&lt;br&gt;category — NVARCHAR(60)&lt;br&gt;model — NVARCHAR(120)&lt;br&gt;description — NVARCHAR(500)&lt;br&gt;gtin — NVARCHAR(14) — Unique per org&lt;br&gt;fibre_composition — NVARCHAR(500)&lt;br&gt;care_instructions — NVARCHAR(500)&lt;br&gt;repair_instructions — NVARCHAR(500)&lt;br&gt;disposal_instructions — NVARCHAR(500)&lt;br&gt;country_of_origin — NVARCHAR(2)&lt;br&gt;substances_of_concern — NVARCHAR(500)&lt;br&gt;espr_compliance — NVARCHAR(16) — enum&lt;br&gt;status — NVARCHAR(12) — enum, Default draft&lt;br&gt;🔗 owning_organization_ID — NVARCHAR(36) — FK, Required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F57C00;fontColor=#E65100;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="640" y="440" width="380" height="380" as="geometry" />
        </mxCell>

        <mxCell id="t-var" value="&lt;b style=&quot;font-size:13px;color:#E65100&quot;&gt;Product Variants&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;color — NVARCHAR(40)&lt;br&gt;size — NVARCHAR(20)&lt;br&gt;sku — NVARCHAR(40) — Unique per product&lt;br&gt;gtin — NVARCHAR(14)&lt;br&gt;weight_g — INTEGER&lt;br&gt;status — NVARCHAR(10) — enum, Default active&lt;br&gt;🔗 product_ID — NVARCHAR(36) — FK, Required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F57C00;fontColor=#E65100;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="340" height="220" as="geometry" />
