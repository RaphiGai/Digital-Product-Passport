        <mxCell id="t-bat" value="&lt;b style=&quot;font-size:13px;color:#E65100&quot;&gt;Batches&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;batch_number — NVARCHAR(40) — Unique per variant&lt;br&gt;production_date — DATE&lt;br&gt;country_of_origin — NVARCHAR(2)&lt;br&gt;production_stage — NVARCHAR(60)&lt;br&gt;co2_footprint_kg — DECIMAL(10, 3)&lt;br&gt;recycled_content_pct — DECIMAL(5, 2)&lt;br&gt;status — NVARCHAR(12) — enum, Default draft&lt;br&gt;🔗 variant_ID — NVARCHAR(36) — FK, Required&lt;br&gt;🔗 factory_ID — NVARCHAR(36) — FK to BP&lt;br&gt;🔗 supplier_ID — NVARCHAR(36) — FK to BP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F57C00;fontColor=#E65100;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
