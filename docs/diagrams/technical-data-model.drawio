        <mxCell id="t-org" value="&lt;b style=&quot;font-size:13px;color:#0D47A1&quot;&gt;Organizations&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;legal_name — NVARCHAR(120) — Required&lt;br&gt;trade_name — NVARCHAR(120)&lt;br&gt;country_iso2 — NVARCHAR(2)&lt;br&gt;city — NVARCHAR(80)&lt;br&gt;gln — NVARCHAR(13)&lt;br&gt;website_url — NVARCHAR(500)&lt;br&gt;contact_email — NVARCHAR(254)&lt;br&gt;tenant_id — NVARCHAR(64) — Required, Unique&lt;br&gt;is_platform_tenant — BOOLEAN — Default false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1976D2;fontColor=#0D47A1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
