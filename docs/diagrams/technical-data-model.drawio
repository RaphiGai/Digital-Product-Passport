        <mxCell id="t-users" value="&lt;b style=&quot;font-size:13px;color:#0D47A1&quot;&gt;Users&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;email — NVARCHAR(254) — Required, Unique per org&lt;br&gt;display_name — NVARCHAR(120)&lt;br&gt;role — NVARCHAR(20) — Required, enum&lt;br&gt;external_user_id — NVARCHAR(120)&lt;br&gt;active — BOOLEAN — Default true&lt;br&gt;🔗 organization_ID — NVARCHAR(36) — FK, Required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1976D2;fontColor=#0D47A1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="320" height="220" as="geometry" />
