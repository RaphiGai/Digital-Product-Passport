        <mxCell id="t-bp" value="&lt;b style=&quot;font-size:13px;color:#0D47A1&quot;&gt;Business Partners&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;name — NVARCHAR(120) — Required&lt;br&gt;country_iso2 — NVARCHAR(2)&lt;br&gt;city — NVARCHAR(80)&lt;br&gt;address — NVARCHAR(200)&lt;br&gt;contact_person — NVARCHAR(120)&lt;br&gt;contact_email — NVARCHAR(254)&lt;br&gt;identifier — NVARCHAR(40)&lt;br&gt;archived — BOOLEAN — Default false&lt;br&gt;🔗 owning_organization_ID — NVARCHAR(36) — FK, Required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1976D2;fontColor=#0D47A1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
