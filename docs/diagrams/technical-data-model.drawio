        <!-- ====== Type mapping legend ====== -->
        <mxCell id="legend-types" value="&lt;b&gt;Type mapping (CDS → HANA SQL)&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;String(n) → NVARCHAR(n) — UTF-16 in HANA&lt;br&gt;LargeString → NCLOB — up to 2 GB&lt;br&gt;Boolean → BOOLEAN&lt;br&gt;Integer → INTEGER — 32-bit signed&lt;br&gt;Decimal(p, s) → DECIMAL(p, s)&lt;br&gt;Date → DATE — YYYYMMDD&lt;br&gt;Timestamp → TIMESTAMP — 100 ns precision&lt;br&gt;UUID → NVARCHAR(36)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;fontColor=#333;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="1440" width="500" height="160" as="geometry" />
        </mxCell>

        <mxCell id="legend-symbols" value="&lt;b&gt;Symbols&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 — Primary key&lt;br&gt;🔗 — Foreign key&lt;br&gt;Required — NOT NULL constraint&lt;br&gt;Unique — UNIQUE constraint&lt;br&gt;enum — Value restricted to a fixed list&lt;br&gt;Default — Default value applied on insert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;fontColor=#333;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="1440" width="380" height="160" as="geometry" />
        </mxCell>

        <mxCell id="legend-edges" value="&lt;b&gt;Edges&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;Solid arrow — foreign key reference, child to parent&lt;br&gt;Thick solid — one-to-one foreign key (item → passport)&lt;br&gt;Dashed arrow — optional reference or cross-organisation&lt;br&gt;Label on arrow — column name when not obvious" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;fontColor=#333;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="1440" width="500" height="160" as="geometry" />
        </mxCell>

