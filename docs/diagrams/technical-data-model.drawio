        <mxCell id="t-dpp" value="&lt;b style=&quot;font-size:13px;color:#4A148C&quot;&gt;DPPs&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;granularity — NVARCHAR(8) — enum, Default item&lt;br&gt;dpp_type — NVARCHAR(12) — enum, Default product&lt;br&gt;status — NVARCHAR(12) — enum, Default draft&lt;br&gt;visibility — NVARCHAR(8) — enum, Default internal&lt;br&gt;current_version — INTEGER — Default 1&lt;br&gt;qr_token — NVARCHAR(128) — Unique, HMAC-signed&lt;br&gt;qr_payload_url — NVARCHAR(500)&lt;br&gt;public_url — NVARCHAR(500)&lt;br&gt;approved_at — TIMESTAMP&lt;br&gt;published_at — TIMESTAMP&lt;br&gt;archived_at — TIMESTAMP&lt;br&gt;valid_from — DATE&lt;br&gt;last_updated — TIMESTAMP&lt;br&gt;aggregated_snapshot — NCLOB — JSON snapshot&lt;br&gt;storytelling — NCLOB — JSON array&lt;br&gt;🔗 product_ID — NVARCHAR(36) — FK, Required&lt;br&gt;🔗 item_ID — NVARCHAR(36) — FK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6A1B9A;fontColor=#4A148C;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="1110" width="400" height="290" as="geometry" />
