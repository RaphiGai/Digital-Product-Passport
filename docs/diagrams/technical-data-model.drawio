        <mxCell id="t-bpr" value="&lt;b style=&quot;font-size:13px;color:#0D47A1&quot;&gt;Business Partner Roles&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;🔑 ID — NVARCHAR(36) — PK&lt;br&gt;role — NVARCHAR(24) — Required, enum&lt;br&gt;🔗 partner_ID — NVARCHAR(36) — FK, Required&lt;hr size=&quot;1&quot;&gt;&lt;i style=&quot;font-size:9px&quot;&gt;Constraint: unique (partner_ID, role)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1976D2;fontColor=#0D47A1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;strokeWidth=2;" vertex="1" parent="1">
