        <mxCell id="title" parent="1" style="text;html=1;fontSize=22;fontStyle=1;align=center;fontColor=#354A5F;" value="DPP Capgemini — Software Architecture" vertex="1">
          <mxGeometry height="32" width="740" x="380" y="16" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;fontSize=11;fontStyle=2;align=center;fontColor=#888;" value="Logical component view (deployment-agnostic): Client → Platform boundary → API → Business Logic → Supporting Libraries → Persistence — Icons: SAP BTP Solution Diagrams (Apache-2.0)" vertex="1">
          <mxGeometry height="20" width="900" x="300" y="48" as="geometry" />
        </mxCell>

        <mxCell id="cl-tier" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;dashed=0;verticalAlign=top;align=left;fontStyle=1;fontColor=#0D47A1;spacingLeft=10;spacingTop=4;fontSize=12;" value="Client Layer  (who calls the system — no business logic, no secrets)" vertex="1">
          <mxGeometry height="90" width="1380" x="60" y="90" as="geometry" />
        </mxCell>
        <mxCell id="cl-company" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontColor=#0D47A1;fontSize=11;align=center;" value="Company user&#xa;(advanced / standard)" vertex="1">
