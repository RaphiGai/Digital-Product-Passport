        </mxCell>

        <mxCell id="pb-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;strokeWidth=2;fontColor=#37474F;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" value="Platform boundary — Application Router terminates auth · XSUAA validates the token&#xa;(single scope: authenticated-user — role and tenant are resolved inside the API layer)&#xa;Detail → BTP Architecture (§1)" vertex="1">
