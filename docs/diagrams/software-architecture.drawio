<mxfile host="app.diagrams.net">
  <diagram name="Software Architecture" id="sw-arch">
    <mxGraphModel dx="2023" dy="784" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0" />
