%%{init: {'theme':'neutral', 'themeVariables': { 'fontSize': '12px'}}}%%
%% Technical data model — physical schema as deployed to HANA Cloud (17 domain
%% tables, main, July 2026). Field-level view; the attribute-free semantic
%% counterpart is erd.mmd. Types follow the HANA HDI mapping of the CDS model
%% (db/*.cds). Notes: deployed object names carry the dpp_ namespace prefix
%% (e.g. dpp_Organizations) — shown here without it; the ProductCategories code
%% list additionally deploys a localized-texts table (dpp_ProductCategories_texts),
%% not drawn.
erDiagram

    %% Organisation layer
    organizations      ||--o{ users                  : "organization_ID"
    organizations      ||--o{ business_partners      : "owning_organization_ID"
    organizations      ||--o{ products               : "owning_organization_ID"
    business_partners  ||--o{ business_partner_roles : "partner_ID"
    business_partners  |o--o{ users                  : "business_partner_ID (portal login)"
    business_partners  |o--o{ documents              : "assigned_partner_ID"

    %% Product layer
    product_categories |o--o{ products               : "category_code"
    products           ||--o{ product_variants       : "product_ID"
    product_variants   ||--o{ batches                : "variant_ID"
    batches            ||--o{ product_items          : "batch_ID"
    business_partners  |o--o{ batches                : "factory_ID"
    business_partners  |o--o{ batches                : "supplier_ID"
    product_variants   ||--o{ product_boms           : "parent_ID"
    product_boms       }o--o| products               : "component_ID"
    batches            ||--o{ batch_components       : "batch_ID"
    product_boms       ||--o{ batch_components       : "bom_ID"
    business_partners  |o--o{ batch_components       : "supplier_ID"
    batch_components   }o--o| batches                : "component_batch_ID"
    batch_components   }o--o| dpps                   : "sub_dpp_ID"
    products           |o--o{ documents              : "product_ID (XOR with batch_ID)"
    batches            |o--o{ documents              : "batch_ID (XOR with product_ID)"

    %% Passport layer
    products           ||--o{ dpps                   : "product_ID"
    batches            |o--o{ dpps                   : "batch_ID"
    product_variants   |o--o{ dpps                   : "variant_ID"
    product_items      |o--|| dpps                   : "item_ID (unique)"
    dpps               ||--o{ qr_codes               : "dpp_ID"
    product_boms       }o--o| dpps                   : "sub_dpp_ID"
    dpps               ||--o{ dpp_versions           : "dpp_ID"
    users              |o--o{ dpp_versions           : "changed_by_ID"
    dpps               |o--o{ dpp_marketing_links    : "dpp_ID (optional)"
    organizations      ||--o{ dpp_marketing_links    : "owning_organization_ID"

    %% Import staging
    organizations      |o--o{ pending_imports        : "owning_organization_ID (raw column)"
    users              |o--o{ pending_imports        : "created_by_ID / reviewed_by_ID"

    organizations {
        nvarchar_36  ID                   PK
        nvarchar_120 legal_name              "Required"
        nvarchar_120 trade_name
        nvarchar_2   country_iso2
        nvarchar_80  city
        nvarchar_13  gln
        nvarchar_500 website_url
        nvarchar_254 contact_email
        nvarchar_64  tenant_id            UK "Required"
        boolean      is_platform_tenant      "Default false"
        nvarchar_36  createdBy_ID         FK "Audit: acting user"
        timestamp    createdAt               "Audit"
        nvarchar_36  changedBy_ID         FK "Audit: acting user"
        timestamp    lastChange              "Audit"
    }

    users {
        nvarchar_36  ID                   PK
        nvarchar_254 email                   "Required, Unique per org"
        nvarchar_120 display_name
        nvarchar_20  role                    "Required, enum: company_advanced, company_user, business_partner"
        nvarchar_120 external_user_id
        boolean      active                  "Default true"
        nvarchar_36  business_partner_ID  FK "role business_partner only, to business_partners"
        nvarchar_20  appearance_theme        "enum, Default green"
        nvarchar_60  username             UK "Required, global login handle"
        nvarchar_255 password_hash           "bcrypt; null = cannot log in"
        boolean      must_reset_password     "Default true"
        timestamp    password_updated_at
        integer      failed_login_count      "Default 0, brute-force counter"
        timestamp    locked_until            "lockout window"
        nvarchar_64  reset_token_hash        "sha256, single-use"
        timestamp    reset_token_expires
        nvarchar_36  organization_ID      FK "Required"
    }

    business_partners {
        nvarchar_36  ID                   PK
        nvarchar_120 name                    "Required"
        nvarchar_2   country_iso2
        nvarchar_80  city
        nvarchar_200 address
        nvarchar_120 contact_person
        nvarchar_254 contact_email
        nvarchar_40  identifier              "GLN, VAT or DUNS"
        boolean      archived                "Default false"
        nvarchar_36  owning_organization_ID FK "Required"
        nvarchar_36  createdBy_ID         FK "Audit: acting user"
        timestamp    createdAt               "Audit"
        nvarchar_36  changedBy_ID         FK "Audit: acting user"
        timestamp    lastChange              "Audit"
    }

    business_partner_roles {
        nvarchar_36  ID                   PK
        nvarchar_24  role                    "Required, enum, Unique with partner_ID"
        nvarchar_36  partner_ID           FK "Required"
    }

    product_categories {
        nvarchar_20   code                PK "Code list (sap.common.CodeList)"
        nvarchar_255  name
        nvarchar_1000 descr
    }

    products {
        nvarchar_36  ID                   PK
        nvarchar_12  product_type            "Required, enum, Default finished"
        nvarchar_120 name                    "Required"
        nvarchar_120 brand
        nvarchar_20  category_code        FK "to product_categories"
        nvarchar_120 model
        nvarchar_500 description
        nvarchar_14  gtin                    "Unique per organisation"
        nvarchar_20  upc
        nvarchar_20  ean
        nvarchar_500 fibre_composition
        nvarchar_500 care_instructions
        nvarchar_500 repair_instructions
        nvarchar_500 disposal_instructions
        nvarchar_500 reuse_instructions
        nvarchar_2   country_of_origin
        nvarchar_500 substances_of_concern
        nvarchar_16  espr_compliance         "enum, Default draft"
        decimal_3_1  durability_score        "0.0 to 10.0"
        decimal_3_1  repairability_score     "0.0 to 10.0"
        nvarchar_500 care_video_url
        nvarchar_500 repair_video_url
        nvarchar_500 disposal_video_url
        nvarchar_500 reuse_video_url
        nvarchar_500 care_products_url
        nvarchar_500 repair_products_url
        nvarchar_500 reuse_products_url
        nvarchar_500 disposal_products_url
        nvarchar_12  status                  "enum, Default draft"
        nclob        storytelling            "JSON array"
        nclob        field_visibility        "JSON map field to public/internal"
        nclob        custom_fields           "JSON, user-defined fields"
        nvarchar_36  owning_organization_ID FK "Required"
        nvarchar_36  createdBy_ID         FK "Audit: acting user"
        timestamp    createdAt               "Audit"
        nvarchar_36  changedBy_ID         FK "Audit: acting user"
        timestamp    lastChange              "Audit"
    }

    product_variants {
        nvarchar_36  ID                   PK
        nvarchar_40  color
        nvarchar_20  size
        nvarchar_40  sku                     "Unique per product"
        nvarchar_14  gtin
        integer      weight_g
        nvarchar_500 image_url
        nclob        image_data              "uploaded image, base64 data URL"
        nvarchar_10  status                  "enum, Default active"
        nclob        field_visibility        "JSON map"
        nclob        custom_fields           "JSON, user-defined fields"
        nvarchar_36  product_ID           FK "Required"
        nvarchar_36  createdBy_ID         FK "Audit: acting user"
        timestamp    createdAt               "Audit"
        nvarchar_36  changedBy_ID         FK "Audit: acting user"
        timestamp    lastChange              "Audit"
    }

    batches {
        nvarchar_36   ID                  PK
        nvarchar_40   batch_number           "Unique per variant"
        date          production_date
        nvarchar_2    country_of_origin
        nvarchar_60   production_stage
        decimal_10_3  co2_footprint_kg
        decimal_5_2   recycled_content_pct
        nvarchar_12   status                 "enum, Default draft"
        nclob         field_visibility       "JSON map"
        nclob         custom_fields          "JSON, user-defined fields"
        nvarchar_36   variant_ID          FK "Required"
        nvarchar_36   factory_ID          FK "to business_partners"
        nvarchar_36   supplier_ID         FK "to business_partners"
        nvarchar_36   createdBy_ID        FK "Audit: acting user"
        timestamp     createdAt              "Audit"
        nvarchar_36   changedBy_ID        FK "Audit: acting user"
        timestamp     lastChange             "Audit"
    }

    product_items {
        nvarchar_36   ID                  PK
        nvarchar_60   serial_number          "Required, Unique per batch"
        nvarchar_60   upi                 UK "Required, globally unique (ESPR UPI)"
        date          manufacturing_date
        nvarchar_12   status                 "enum, Default active"
        nvarchar_36   batch_ID            FK "Required"
        nvarchar_36   createdBy_ID        FK "Audit: acting user"
        timestamp     createdAt              "Audit"
        nvarchar_36   changedBy_ID        FK "Audit: acting user"
        timestamp     lastChange             "Audit"
    }

    product_boms {
        nvarchar_36   ID                  PK
        nvarchar_120  component_name
        nvarchar_60   component_category
        nvarchar_500  component_fibre_composition
        decimal_10_3  quantity
        nvarchar_8    unit                   "percent, kg, m, pcs"
        nvarchar_8    quantity_visibility    "enum, Default internal"
        nvarchar_60   component_role
        boolean       is_mandatory           "Default true"
        nvarchar_500  external_dpp_url       "external supplier DPP link"
        decimal_10_4  ext_co2_footprint      "per BOM unit"
        decimal_5_2   ext_recycled_content_pct
        nvarchar_16   ext_espr_compliance    "enum, external components"
        nvarchar_12   status                 "enum, Default active"
        nvarchar_8    visibility             "enum, Default public"
        nvarchar_36   parent_ID           FK "Required, to product_variants"
        nvarchar_36   component_ID        FK "to products, null = external"
        nvarchar_36   sub_dpp_ID          FK "to dpps, optional"
        nvarchar_36   createdBy_ID        FK "Audit: acting user"
        timestamp     createdAt              "Audit"
        nvarchar_36   changedBy_ID        FK "Audit: acting user"
        timestamp     lastChange             "Audit"
    }

    batch_components {
        nvarchar_36   ID                  PK
        nvarchar_40   external_batch_number
        nvarchar_36   batch_ID            FK "Required"
        nvarchar_36   bom_ID              FK "Required, to product_boms"
        nvarchar_36   supplier_ID         FK "to business_partners"
        nvarchar_36   component_batch_ID  FK "to batches"
        nvarchar_36   sub_dpp_ID          FK "to dpps"
    }

    documents {
        nvarchar_36   ID                  PK
        nvarchar_32   doc_type               "Required, enum, Default certificate"
        nvarchar_200  title                  "Required, Unique per product / batch"
        nvarchar_8    visibility             "enum, Default internal"
        nvarchar_200  issuer
        date          issue_date
        date          valid_until
        nvarchar_36   assigned_partner_ID FK "to business_partners, doc responsibility"
        blob          content                "native media stream"
        nvarchar_128  mime_type
        nvarchar_255  file_name
        bigint        file_size              "bytes"
        nvarchar_36   product_ID          FK "XOR with batch_ID"
        nvarchar_36   batch_ID            FK "XOR with product_ID"
        nvarchar_36   createdBy_ID        FK "Audit: acting user"
        timestamp     createdAt              "Audit"
        nvarchar_36   changedBy_ID        FK "Audit: acting user"
        timestamp     lastChange             "Audit"
    }

    dpps {
        nvarchar_36   ID                  PK
        nvarchar_12   dpp_type               "enum, Default product"
        nvarchar_12   status                 "enum, Default draft"
        nvarchar_8    visibility             "enum, Default internal"
        integer       current_version        "Default 1"
        nvarchar_256  qr_token            UK "structured signed token"
        nvarchar_500  qr_payload_url
        nvarchar_500  public_url
        timestamp     approved_at
        timestamp     published_at
        timestamp     archived_at
        date          valid_from
        timestamp     last_updated
        nclob         aggregated_snapshot    "approve baseline JSON"
        nclob         storytelling           "JSON array"
        nvarchar_64   baseline_content_hash  "drift anchor"
        nvarchar_36   product_ID          FK "Required"
        nvarchar_36   batch_ID            FK
        nvarchar_36   variant_ID          FK
        nvarchar_36   item_ID             FK "Unique, one DPP per item"
        nvarchar_36   createdBy_ID        FK "Audit: acting user"
        timestamp     createdAt              "Audit"
        nvarchar_36   changedBy_ID        FK "Audit: acting user"
        timestamp     lastChange             "Audit"
    }

    qr_codes {
        nvarchar_36   ID                  PK
        nvarchar_500  qr_value               "encoded URL on the label"
        nvarchar_500  qr_image_url
        nvarchar_10   status                 "enum, Default active"
        timestamp     created_at
        timestamp     replaced_at
        nvarchar_36   dpp_ID              FK "Required"
    }

    dpp_marketing_links {
        nvarchar_36   ID                  PK
        nvarchar_20   link_type              "enum, Default advertisement"
        nvarchar_200  title                  "Required"
        nvarchar_300  subtitle
        nvarchar_500  url
        nvarchar_10   media_type             "enum, Default image"
        nvarchar_16   placement              "enum, Default discover_more"
        nvarchar_500  image_url
        nclob         image_data             "uploaded thumbnail, base64"
        integer       display_order          "Default 0"
        boolean       is_active              "Default true"
        date          valid_from
        date          valid_to
        nvarchar_36   owning_organization_ID FK "Required, tenant scope"
        nvarchar_36   dpp_ID              FK "optional, null = all org DPPs"
        nvarchar_36   createdBy_ID        FK "Audit: acting user"
        timestamp     createdAt              "Audit"
        nvarchar_36   changedBy_ID        FK "Audit: acting user"
        timestamp     lastChange             "Audit"
    }

    dpp_versions {
        nvarchar_36   ID                  PK
        integer       version_number         "Required"
        timestamp     snapshot_date
        nvarchar_500  change_reason
        nvarchar_10   source                 "enum-like, Default publish: publish or approve"
        nclob         snapshot_data          "frozen internal state JSON"
        nclob         consumer_snapshot      "frozen consumer DTO, publish rows only"
        nvarchar_64   content_hash           "normalized content hash"
        nvarchar_36   dpp_ID              FK "Required"
        nvarchar_36   changed_by_ID       FK "to users"
    }

    pending_imports {
        nvarchar_36   ID                  PK
        nvarchar_30   entity_type            "products, variants, batches, bom, business_partners"
        nvarchar_255  file_name
        integer       total_rows
        integer       valid_rows
        integer       skipped_rows
        nclob         rows_data              "JSON, parsed rows"
        nclob         validation_issues      "JSON"
        nvarchar_20   status                 "pending, approved, rejected"
        nvarchar_500  review_note
        nvarchar_36   owning_organization_ID    "raw column, no association"
        timestamp     created_at
        nvarchar_36   created_by_ID       FK "to users"
        timestamp     reviewed_at
        nvarchar_36   reviewed_by_ID      FK "to users"
    }
