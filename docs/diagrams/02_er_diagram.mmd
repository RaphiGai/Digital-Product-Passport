erDiagram
    Organizations ||--o{ Facilities      : "operates"
    Organizations ||--o{ Users           : "employs"
    Organizations ||--o{ Products        : "owns"
    Organizations ||--o{ DPPs            : "issues"
    Organizations ||--o{ Materials       : "owns master"
    Facilities    ||--o{ DPPs            : "manufactures at"
    Products      ||--o{ DPPs            : "has passport"

    Materials          ||--o{ MaterialComponents       : "parent of"
    Materials          ||--o{ MaterialComponents       : "child in"
    Materials          ||--o{ MaterialComposition      : "used in DPP via"

    DPPs ||--o{ MaterialComposition       : "composes of"
    DPPs ||--o{ ComplianceStatements      : "states"
    DPPs ||--o{ Documents                 : "evidences"
    DPPs ||--o{ SubstancesOfConcern       : "declares"
    DPPs ||--o{ CareInstructions          : "carries"
    DPPs ||--|| SustainabilityIndicators  : "measured by"
    DPPs ||--o{ SupplyChainSteps          : "traces"
    DPPs ||--o{ LifecycleEvents           : "logs"

    ComplianceStatements }o--|| Documents     : "evidence_document"
    SupplyChainSteps     }o--|| Facilities    : "at"
    SupplyChainSteps     }o--|| Organizations : "by"
    LifecycleEvents      }o--|| Organizations : "actor"

    Organizations {
        string ID PK
        string tenant_id UK
        string legal_name
        enum   organization_type
    }
    DPPs {
        string ID PK
        string product_ID FK
        string issuing_organization_ID FK
        enum   status
        enum   visibility
        enum   verification_status
        enum   granularity_level
        string qr_token UK
        ts     published_at
    }
    Products {
        string ID PK
        string gtin
        string owning_organization_ID FK
    }
    Materials {
        string ID PK
        string owning_organization_ID FK
        string name
        enum   material_class
        string country_of_origin
        dec    recycled_content_pct
        enum   verification_status
        string supplier_ID FK
        dec    co2_footprint_kg
        dec    water_usage_l
        dec    energy_usage_kwh
    }
    MaterialComponents {
        string ID PK
        string parent_material_ID FK
        string child_material_ID FK
        dec    percentage
    }
    MaterialComposition {
        string ID PK
        string dpp_ID FK
        string material_ID FK
        dec    percentage
    }
