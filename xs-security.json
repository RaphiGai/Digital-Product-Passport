{
  "xsappname": "dpp-capgemini",
  "tenant-mode": "shared",
  "description": "Security profile for the DPP Capgemini backend",
  "scopes": [
    {
      "name": "$XSAPPNAME.admin",
      "description": "Organization administrator: full CRUD within own tenant + user management"
    },
    {
      "name": "$XSAPPNAME.advanced",
      "description": "Company advanced user: full CRUD on products, BOM, DPPs within own tenant"
    },
    {
      "name": "$XSAPPNAME.user",
      "description": "Company user: read tenant data + create/update product items and DPPs"
    },
    {
      "name": "$XSAPPNAME.viewer",
      "description": "Read-only access to own tenant's DPP data"
    },
    {
      "name": "$XSAPPNAME.authority",
      "description": "Authority access: read-only across all tenants"
    }
  ],
  "attributes": [
    {
      "name": "tenant",
      "description": "Tenant / organization identifier used for row-level isolation",
      "valueType": "string"
    }
  ],
  "role-templates": [
    {
      "name": "Admin",
      "description": "DPP organization administrator",
      "scope-references": ["$XSAPPNAME.admin"],
      "attribute-references": ["tenant"]
    },
    {
      "name": "Advanced",
      "description": "DPP advanced company user",
      "scope-references": ["$XSAPPNAME.advanced"],
      "attribute-references": ["tenant"]
    },
    {
      "name": "User",
      "description": "DPP company user",
      "scope-references": ["$XSAPPNAME.user"],
      "attribute-references": ["tenant"]
    },
    {
      "name": "Viewer",
      "description": "DPP viewer (company user)",
      "scope-references": ["$XSAPPNAME.viewer"],
      "attribute-references": ["tenant"]
    },
    {
      "name": "Authority",
      "description": "Market surveillance authority (cross-tenant read-only)",
      "scope-references": ["$XSAPPNAME.authority"]
    }
  ],
  "role-collections": [
    {
      "name": "DPP_Admin",
      "description": "Grants DPP organization admin privileges",
      "role-template-references": ["$XSAPPNAME.Admin"]
    },
    {
      "name": "DPP_Advanced",
      "description": "Grants DPP advanced company user privileges",
      "role-template-references": ["$XSAPPNAME.Advanced"]
    },
    {
      "name": "DPP_User",
      "description": "Grants DPP company user privileges",
      "role-template-references": ["$XSAPPNAME.User"]
    },
    {
      "name": "DPP_Viewer",
      "description": "Grants DPP viewer privileges",
      "role-template-references": ["$XSAPPNAME.Viewer"]
    },
    {
      "name": "DPP_Authority",
      "description": "Grants authority privileges (cross-tenant read-only)",
      "role-template-references": ["$XSAPPNAME.Authority"]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.eu10-004.hana.ondemand.com/**",
      "https://*.cfapps.eu10.hana.ondemand.com/**",
      "http://localhost:5000/**"
    ]
  }
}
