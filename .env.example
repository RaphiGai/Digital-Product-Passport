# --- CAP runtime ---
NODE_ENV=development
CDS_ENV=development
PORT=4004

# --- Public endpoint ---
PUBLIC_BASE_URL=http://localhost:4004
# 16+ chars random; used to sign QR tokens (HMAC-SHA256)
QR_TOKEN_HMAC_SECRET=change-me-to-a-long-random-string

# --- App-managed auth (own login, replaces XSUAA) ---
# 16+ chars random; signs the dpp_session login cookie (HMAC-SHA256).
SESSION_SECRET=change-me-to-a-long-random-string
# Where to land after a successful login (approuter root by default).
POST_LOGIN_REDIRECT=/

# --- Self-service password reset (email) ---
# Reset-link lifetime in minutes (default 60).
PASSWORD_RESET_TTL_MIN=60
# SMTP for the reset email. If MAIL_HOST is UNSET (e.g. local dev), no mail is sent and
# the reset link is printed to the server console instead. On BTP set these via env or a
# user-provided service.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@dpp-studio.example

# --- AI assistant (Google Gemini via Google AI Studio) ---
# API key from Google AI Studio. Keep it OUT of git — set locally here (.env is
# gitignored) and on BTP via the dpp-secrets user-provided service. If unset, the
# assistant endpoints return a clean "not available" message.
GEMINI_API_KEY=
# Model for the chat/orchestration loop (fast). Optional; default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# Optional stronger model for document extraction; defaults to GEMINI_MODEL.
GEMINI_MODEL_EXTRACT=
# Optional API base URL override (default: https://generativelanguage.googleapis.com/v1beta)
GEMINI_BASE_URL=
