{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "sessionTimeout": 30,
  "logout": { "logoutEndpoint": "/do/logout" },
  "routes": [
    {
      "source": "^/healthz$",
      "target": "/healthz",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/public/(.*)$",
      "target": "/public/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/assets/(.*)$",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^/consumer\\.html.*$",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^(.*)$",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    }
  ]
}
