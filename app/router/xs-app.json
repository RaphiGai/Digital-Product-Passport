{
  "welcomeFile": "/login",
  "authenticationMethod": "none",
  "sessionTimeout": 30,
  "routes": [
    {
      "source": "^/healthz$",
      "target": "/healthz",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/login$",
      "target": "/login",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/auth/(.*)$",
      "target": "/auth/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/public/(.*)$",
      "target": "/public/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/ai/(.*)$",
      "target": "/ai/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/\\$api-docs/(.*)$",
      "target": "/$api-docs/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/$",
      "target": "/$api-docs/odata/v4/dpp",
      "destination": "srv-api",
      "authenticationType": "none"
    }
  ]
}
